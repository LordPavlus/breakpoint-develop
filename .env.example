# === База данных (Neon Postgres) ===
# DATABASE_URL — pooled-подключение (через PgBouncer), используется в рантайме
# приложения через driver adapter (src/lib/prisma.ts).
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
# DIRECT_URL — прямое (unpooled) подключение, нужно Prisma Migrate/db push/studio
# (prisma.config.ts) для advisory locks и shadow database.
DIRECT_URL="postgresql://user:password@host/db?sslmode=require"

# === Авторизация (Auth.js v5) — Фаза 1 ===
# Секрет для подписи JWT-сессий, сгенерировать: npx auth secret
AUTH_SECRET=""

# === Email-уведомления (Resend) — Фаза 1 ===
# OTP-коды для входа, письма о бронировании
RESEND_API_KEY=""

# === Платежи (ЮKassa REST API v3) — Фаза 1 ===
YOOKASSA_SHOP_ID=""
YOOKASSA_SECRET_KEY=""

# === Файловое хранилище (Cloudflare R2, S3-совместимое) — Фаза 1 ===
# Фото профилей тренеров/игроков, presigned PUT с клиента
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# === Базовый URL приложения ===
# Используется для редиректов оплаты ЮKassa, ссылок в email-уведомлениях и т.д.
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# === Cron (Vercel Cron Jobs) — Фаза 2 ===
# Секрет для авторизации входящих запросов от Vercel Cron (заголовок
# Authorization: Bearer <CRON_SECRET>). Если не задан — эндпоинт открыт
# (для локальной разработки).
CRON_SECRET=""

# === Push-уведомления (Web Push / VAPID) — Фаза 3 ===
# Пара ключей генерируется локально (не требует внешнего аккаунта):
# npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
# Контакт для push-сервисов (mailto: или https:-URL), требование протокола VAPID
VAPID_SUBJECT="mailto:support@breakpoint.moscow"
# Тот же публичный ключ, что и VAPID_PUBLIC_KEY — нужен клиенту для подписки.
# Если не задан — переключатель push-уведомлений в кабинете не отображается.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# === Вход через Telegram (Фаза 3) ===
# 1. Создать бота через @BotFather: команда /newbot.
# 2. Привязать домен сайта: команда /setdomain (для prod — домен приложения,
#    для локальной разработки Telegram Login Widget требует https — используйте
#    туннель типа ngrok и временно укажите его домен через /setdomain).
# TELEGRAM_BOT_TOKEN — токен бота от @BotFather, используется на сервере для
# проверки подписи данных виджета. Секрет, не публикуется.
TELEGRAM_BOT_TOKEN=""
# NEXT_PUBLIC_TELEGRAM_BOT_USERNAME — username бота без @ (напр. "BreakPointMoscowBot"),
# нужен виджету на клиенте. Если не задан — кнопка входа через Telegram не отображается.
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=""
